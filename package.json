    "allure-commandline": "^2.38.1",
    "cypress": "^15.14.1",
    "cypress-xpath": "^2.0.1",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "cypress-real-events": "^1.15.0"
  }
